NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Reactor face-swap API (ngrok or hosted endpoint)
REACTOR_API_URL=https://coherent-repeatedly-frog.ngrok-free.app/reactor/image

# Live stream iframe URL (optional override)
# Production:
# NEXT_PUBLIC_LIVE_STREAM_URL=https://webcastlive.co.in/cloud-player/player/player.php?event_id=3935
# Local dummy test (direct MP4, recommended):
# NEXT_PUBLIC_LIVE_STREAM_URL=https://test-videos.co.uk/vids/bigbuckbunny/mp4/h264/360/Big_Buck_Bunny_360_10s_1MB.mp4
# Same-origin iframe test page (optional):
# NEXT_PUBLIC_LIVE_STREAM_URL=/test-live-stream.html
# Optional YouTube test (may log "unload is not allowed" in Chrome — harmless):
# NEXT_PUBLIC_LIVE_STREAM_URL=https://www.youtube.com/embed/jfKfPfyJRdk?rel=0&modestbranding=1

# Optional: for npm run db:setup (Supabase Dashboard → Settings → Database → URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
